
# Google Gemini (primary AI pipeline)
GOOGLE_CLOUD_API_KEY=your_gemini_api_key_here
AI_MODEL=gemini-3.1-pro-preview
GEMINI_MODEL_VISION=gemini-2.0-flash
GEMINI_MODEL_ANALYSIS=gemini-2.0-flash
GEMINI_MODEL_CODEGEN=gemini-2.0-flash
GEMINI_CONCURRENCY=10

# Auth (leave empty or remove to disable password protection)
# SITE_PASSWORD=

# Deployment (used by deploy.sh)
SERVICE_NAME=aistudio
GCP_REGION=asia-south1
