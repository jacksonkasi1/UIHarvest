{
  "name": "ui-harvest",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/main.ts",
    "extract": "bun run src/main.ts",
    "serve": "bun run src/serve.ts",
    "build:web": "bun run --cwd web build",
    "build": "bun run build:web",
    "start:server": "bun run build:web && bun run src/serve.ts",
    "dev": "concurrently \"bun run src/serve.ts\" \"bun run --cwd web dev --host 0.0.0.0 --port 5173\"",
    "web": "concurrently \"bun run src/serve.ts\" \"bun run --cwd web dev --host 0.0.0.0 --port 5173\"",
    "generate:snapshot": "bun run scripts/generate-base-snapshot.ts",
    "docker:build": "docker build -t uiharvest .",
    "docker:run": "docker run -p 8080:8080 --env-file .env uiharvest",
    "deploy": "bash deploy.sh"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.43",
    "@google-cloud/firestore": "^8.3.0",
    "@google/genai": "^1.44.0",
    "ai": "^6.0.116",
    "cookie-parser": "^1.4.7",
    "culori": "^4.0.2",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "playwright": "^1.48.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@webcontainer/snapshot": "^0.1.0",
    "bun-types": "^1.1.0",
    "concurrently": "^9.2.1",
    "shadcn": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
