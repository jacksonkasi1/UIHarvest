{
  "name": "ui-harvest",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run src/main.ts",
    "extract": "bun run src/main.ts",
    "serve": "bun run src/serve.ts",
    "web": "concurrently \"bun run src/serve.ts --vite-url=http://localhost:5173\" \"bun run --cwd web dev --host 0.0.0.0 --port 5173\""
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "culori": "^4.0.2",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "playwright": "^1.48.0",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "bun-types": "^1.1.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.0"
  }
}
